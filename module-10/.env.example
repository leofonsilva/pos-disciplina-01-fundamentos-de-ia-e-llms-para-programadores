# OpenRouter Configuration
OPENROUTER_API_KEY=""
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME="My Example"

# Models
NLP_MODEL="arcee-ai/trinity-large-preview:free"

# Embeddings (using Transformers.js locally)
EMBEDDING_MODEL="Xenova/all-MiniLM-L6_v2"

# Neo4j
NEO4J_USER=
NEO4J_PASSWORD=
NEO4J_URI=bot://localhost:7687
NEO4J_DATABASE=neo4j

# Vector search threshold
NEO4J_VECTOR_THRESHOLD=0.9